# ============================================
# Dashboard Backend - Environment Variables
# ============================================
# For local development (non-Docker)
# When running in Docker, these are overridden by
# gold-trading-stack/docker-compose.yml
# ============================================

# Database Configuration (Local Development)
# For Docker runtime, use postgres:5432 instead of localhost
DB_URL=jdbc:postgresql://localhost:5432/gold_trading_bot?currentSchema=dashboard
DB_USERNAME=dashboard_app
DB_PASSWORD=dashboard_pass_change_me

# Application Port
APP_PORT=8088

# JWT Configuration
# ⚠️  CHANGE THESE FOR PRODUCTION!
# Generate with: openssl rand -base64 64
APP_JWT_SECRET_BASE64=Q2hhbmdlVGhpc1NlY3JldEtleUZvclByb2R1Y3Rpb24xMjM0NTY3ODkwQQ==
APP_JWT_ACCESS_TOKEN_MINUTES=15
APP_JWT_REFRESH_TOKEN_DAYS=30

# MT5 Encryption Key (16 characters minimum)
# ⚠️  CHANGE THIS FOR PRODUCTION!
APP_MT5_ENCRYPTION_KEY=change-this-key-16

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JVM Options
JAVA_TOOL_OPTIONS=-Duser.timezone=Asia/Ho_Chi_Minh
